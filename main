    "Chakram", "Sledgehammer", "Spiked Purse", "Bunny Shoes", "Parasol", "Axe", "Chain Mace",
    "Spiked Stanley", "Kitty Claw Knuckles"
}

local function IsWeapon(name)
    if not name then return false end
    name = name:lower()
    for _,w in pairs(WEAPONS) do if name == w:lower() then return true end end
    return false
end

local function GetWeapons(player)
    local list = {}
    if not player or not player:FindFirstChild("Backpack") then return list end
    for _,item in pairs(player.Backpack:GetChildren()) do
        if IsWeapon(item.Name) then table.insert(list, item) end
    end
    if player:FindFirstChild("Character") then
        for _,item in pairs(player.Character:GetChildren()) do
            if IsWeapon(item.Name) then table.insert(list, item) end
        end
    end
    return list
end
